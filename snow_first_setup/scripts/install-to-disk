#!/bin/bash

if [ -z "$1" ] || [ -z "$2" ] || [ -z "$3" ]; then
    echo "usage:"
    echo "install-to-disk <image> <filesystem> <device> [fde] [passphrase]"
    echo "  fde: 'true' or 'false' (optional, default: false)"
    echo "  passphrase: required if fde is 'true'"
    exit 5
fi

if ! [ "$UID" == "0" ]; then
    echo "this script must be run with super user privileges"
    exit 6
fi

# Parse FDE parameters
FDE="${4:-false}"
PASSPHRASE="$5"

# Validate FDE parameter
if [ "$FDE" != "true" ] && [ "$FDE" != "false" ]; then
    echo "fde parameter must be 'true' or 'false', got: $FDE"
    exit 7
fi

# If FDE is enabled, passphrase is required
if [ "$FDE" == "true" ] && [ -z "$PASSPHRASE" ]; then
    echo "passphrase is required when fde is 'true'"
    exit 8
fi

# we support btrfs and ext4 filesystems right now
if [ "$2" != "btrfs" ] && [ "$2" != "ext4" ]; then
    echo "unsupported filesystem: $2"
    exit 10
fi

if ! [ -b "$3" ]; then
    echo "device '$3' is not a valid block device"
    exit 9
fi

rm -rf /tmp/installmnt

# Make a temporary mount point in /tmp
mkdir -p /tmp/installmnt
MOUNT=/tmp/installmnt/

set -x
umount "$MOUNT" 2>/dev/null || true

set -e

DEVICE="$3"
parted "$DEVICE" --script mklabel gpt
# use the ddi partition type for EFI system partition

parted "$DEVICE" --align=optimal --script mkpart ESP fat32 1MiB 1024MiB
parted "$DEVICE" --script set 1 boot on
parted "$DEVICE" --script type 1 c12a7328-f81f-11d2-ba4b-00a0c93ec93b
parted "$DEVICE" --script mkpart "ROOT" "$2" 1024MiB 100%
parted "$DEVICE" --script type 2 4F68BCE3-E8CD-4DB1-96E7-FBCAF984B709
partprobe "${DEVICE}"
# adjust partition names for devices that require 'p' before partition number
if [[ "$DEVICE" == *"nvme"* || "$DEVICE" == *"mmcblk"* || "$DEVICE" == *"loop"* ]]; then
    DEVICE="${DEVICE}p"
fi

udevadm settle

mkfs.fat -n EFI-SYSTEM "${DEVICE}1"

# Determine the root device - either encrypted or plain
ROOT_DEVICE="${DEVICE}2"

# Set up LUKS encryption if FDE is enabled
if [ "$FDE" == "true" ]; then
    echo "Setting up LUKS encryption on ${DEVICE}2..."
    echo -n "$PASSPHRASE" | cryptsetup luksFormat --type luks2 "${DEVICE}2" -
    echo -n "$PASSPHRASE" | cryptsetup open "${DEVICE}2" cryptroot -
    ROOT_DEVICE="/dev/mapper/cryptroot"

    # Enroll TPM2 if available
    if [ -e /sys/class/tpm/tpm0 ] && command -v systemd-cryptenroll &> /dev/null; then
        echo "TPM2 detected, enrolling device with systemd-cryptenroll..."
        echo -n "$PASSPHRASE" | systemd-cryptenroll --tpm2-device=auto --tpm2-pcrs=0+7 "${DEVICE}2" --password || {
            echo "Warning: TPM2 enrollment failed, continuing with passphrase-only encryption"
        }
    fi
fi

# Format the root partition (either encrypted mapper or plain partition)
if [ "$2" == "btrfs" ]; then
    mkfs.btrfs -f -L root "$ROOT_DEVICE"
elif [ "$2" == "ext4" ]; then
    mkfs.ext4 -O verity -L root "$ROOT_DEVICE"
fi

mount "$ROOT_DEVICE" "$MOUNT" || { echo "Failed to mount root partition ($ROOT_DEVICE) to $MOUNT"; exit 20; }
mkdir "${MOUNT}/boot"
mount "${DEVICE}1" "${MOUNT}/boot" || { echo "Failed to mount EFI partition (${DEVICE}1) to ${MOUNT}/boot"; exit 21; }

bootc install to-filesystem --composefs-backend --bootloader systemd --skip-finalize --source-imgref docker://"$1" \
    --karg rd.auto \
    --karg rd.lvm=1 \
    --karg rd.dm=1 \
    --karg rd.md=1 \
    --karg rd.luks=1 \
     "$MOUNT"

# unmount everything - but maybe we will want to keep it mounted for doing further setup.
umount "${MOUNT}/boot"
umount "$MOUNT"

# Close LUKS device if it was opened
if [ "$FDE" == "true" ]; then
    cryptsetup close cryptroot
fi