<?xml version="1.0" encoding="UTF-8"?>
<interface>
    <requires lib="gtk" version="4.0"/>
    <requires lib="libadwaita" version="1.0" />
    <template class="VanillaWelcomeInstall" parent="AdwBin">
        <property name="halign">fill</property>
        <property name="valign">fill</property>
        <property name="hexpand">true</property>
        <child>
            <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="valign">center</property>
                <property name="halign">center</property>
                <property name="spacing">24</property>
                <property name="margin-top">48</property>
                <property name="margin-bottom">48</property>

                <!-- Large variant emoji -->
                <child>
                    <object class="GtkLabel" id="lbl_emoji">
                        <property name="label">🐟</property>
                        <style>
                            <class name="welcome-emoji" />
                        </style>
                    </object>
                </child>

                <!-- Title -->
                <child>
                    <object class="GtkLabel" id="lbl_title">
                        <property name="label" translatable="yes">Welcome to TunaOS</property>
                        <property name="wrap">true</property>
                        <property name="max-width-chars">40</property>
                        <property name="justify">center</property>
                        <style>
                            <class name="title-1" />
                        </style>
                    </object>
                </child>

                <!-- Description -->
                <child>
                    <object class="GtkLabel" id="lbl_desc">
                        <property name="label" translatable="yes">Install or try TunaOS on your computer</property>
                        <property name="wrap">true</property>
                        <property name="max-width-chars">50</property>
                        <property name="justify">center</property>
                        <style>
                            <class name="body" />
                        </style>
                    </object>
                </child>

                <!-- Buttons -->
                <child>
                    <object class="GtkBox">
                        <property name="spacing">12</property>
                        <property name="halign">center</property>
                        <property name="margin-top">12</property>
                        <child>
                            <object class="GtkButton" id="btn_next">
                                <property name="label" translatable="yes">Install</property>
                                <style>
                                    <class name="pill" />
                                    <class name="suggested-action" />
                                </style>
                            </object>
                        </child>
                        <child>
                            <object class="GtkButton" id="btn_try">
                                <property name="label" translatable="yes">Try</property>
                                <style>
                                    <class name="pill" />
                                </style>
                            </object>
                        </child>
                        <child>
                            <object class="GtkButton" id="btn_access">
                                <property name="label" translatable="yes">Accessibility</property>
                                <style>
                                    <class name="pill" />
                                </style>
                            </object>
                        </child>
                    </object>
                </child>
            </object>
        </child>
    </template>
</interface>
