#!/bin/bash
set -euo pipefail

# TunaOS installer — bootc-based disk installation
# Outputs JSON Lines for streaming progress to the installer GUI
#
# Usage: install-to-disk <image> <device> <filesystem> [fde] [passphrase] [tpm2] [target_imgref]
#   image        - container image reference (containers-storage:localhost/...)
#   device       - block device path (/dev/sdX, /dev/nvme0n1, etc.)
#   filesystem   - filesystem type (xfs, btrfs, ext4)
#                - "btrfs-subvols" enables btrfs with @, @home, @snapshots subvolumes
#   fde          - "true" or "false" for full disk encryption (default: false)
#   passphrase   - encryption passphrase (required if fde=true, not tpm2-only)
#   tpm2         - "true" or "false" for TPM2 auto-unlock (default: false)
#   target_imgref - upstream image ref for update tracking (e.g. ghcr.io/tuna-os/yellowfin:gnome-hwe)

# ── JSON progress helpers ──────────────────────────────────────────────────────

progress_step() {
    local step="$1" total="$2" name="$3"
    echo "{\"type\":\"step\",\"step\":${step},\"total_steps\":${total},\"step_name\":\"${name}\"}"
}

progress_error() {
    echo "{\"type\":\"error\",\"message\":\"${1}\"}"
}

progress_complete() {
    echo "{\"type\":\"complete\",\"message\":\"${1:-Installation complete!}\"}"
}

# ── Argument validation ────────────────────────────────────────────────────────

if [ -z "${1:-}" ] || [ -z "${2:-}" ] || [ -z "${3:-}" ]; then
    progress_error "Missing arguments. Usage: install-to-disk <image> <device> <filesystem> [fde] [passphrase] [tpm2] [target_imgref]"
    exit 5
fi

if [ "$UID" != "0" ]; then
    progress_error "This script must be run with super user privileges"
    exit 6
fi

IMAGE="$1"
DEVICE="$2"
FILESYSTEM="$3"
FDE="${4:-false}"
PASSPHRASE="${5:-}"
TPM2="${6:-false}"
TARGET_IMGREF="${7:-}"
HOSTNAME_ARG="${8:-}"

if ! [ -b "$DEVICE" ]; then
    progress_error "Device '${DEVICE}' is not a valid block device"
    exit 9
fi

if [ "$FDE" != "true" ] && [ "$FDE" != "false" ]; then
    progress_error "FDE parameter must be 'true' or 'false', got: ${FDE}"
    exit 7
fi

if [ "$TPM2" != "true" ] && [ "$TPM2" != "false" ]; then
    progress_error "TPM2 parameter must be 'true' or 'false', got: ${TPM2}"
    exit 8
fi

if [ "$FDE" == "true" ] && [ "$TPM2" != "true" ] && [ -z "$PASSPHRASE" ]; then
    progress_error "FDE is enabled but no passphrase provided (and TPM2 is off)"
    exit 10
fi

# Auto-detect upstream target ref if not supplied
# Strip containers-storage: prefix so podman inspect gets a bare image ref
if [ -z "$TARGET_IMGREF" ]; then
    _inspect_ref="${IMAGE#containers-storage:}"
    TARGET_IMGREF=$(podman inspect "$_inspect_ref" --format '{{range .RepoTags}}{{.}}\n{{end}}' 2>/dev/null \
        | grep -v '^localhost/' | grep -v '^$' | head -1 || true)
fi

# Normalise filesystem: btrfs-subvols is btrfs + subvolume layout
BTRFS_SUBVOLS=false
FS_TYPE="$FILESYSTEM"
if [ "$FILESYSTEM" == "btrfs-subvols" ]; then
    FS_TYPE="btrfs"
    BTRFS_SUBVOLS=true
fi

case "$FS_TYPE" in
    xfs|btrfs|ext4) ;;
    *)
        progress_error "Unsupported filesystem: ${FILESYSTEM}. Supported: xfs, btrfs, btrfs-subvols, ext4"
        exit 11
        ;;
esac

# ── Temp space for bootc layer import ─────────────────────────────────────────
# The live rootfs overlay is tiny (~800 MB).  bootc and containers/image write
# large temporary blobs to /var/tmp (largest single layer can be 2-3 GB).
# Mount a 4 GB tmpfs over /var/tmp so the import always succeeds.
# This is safe: the tmpfs is freed automatically when the process exits.
if mountpoint -q /var/tmp; then
    umount /var/tmp 2>/dev/null || true
fi
mount -t tmpfs -o size=4G tmpfs /var/tmp

# ── Detect live-environment SELinux state ─────────────────────────────────────
# Live ISOs boot with enforcing=0 which causes bootc/ostree to fail setting
# security.selinux xattrs (EOPNOTSUPP). --disable-selinux lets the install
# proceed; the installed system re-enables SELinux on first boot via relabeling.
BOOTC_SELINUX_FLAG=""
if grep -q 'enforcing=0\|selinux=0' /proc/cmdline 2>/dev/null; then
    BOOTC_SELINUX_FLAG="--disable-selinux"
fi

# ── Unmount any existing mounts on the target device ─────────────────────────
umount -R /tmp/install_mount 2>/dev/null || true
umount -R /run/bootc/mounts/rootfs 2>/dev/null || true
umount -R /run/bootc/storage 2>/dev/null || true
# Lazy-unmount any lingering device mounts
for part in "${DEVICE}"*; do
    umount -l "$part" 2>/dev/null || true
done

MOUNT="/tmp/install_mount"
mkdir -p "$MOUNT"

# ── Cleanup trap ──────────────────────────────────────────────────────────────
cleanup() {
    sync || true
    umount -R "$MOUNT" 2>/dev/null || true
    if [ "$FDE" == "true" ] && cryptsetup status tunaos-root &>/dev/null; then
        cryptsetup close tunaos-root 2>/dev/null || true
    fi
    umount /var/tmp 2>/dev/null || true
}
trap cleanup EXIT

# Write /etc/hostname to an already-mounted installed root
__apply_hostname() {
    local mnt="$1"
    if [ -n "$HOSTNAME_ARG" ] && [ -d "$mnt/etc" ]; then
        echo "$HOSTNAME_ARG" > "${mnt}/etc/hostname"
    fi
}


# ══════════════════════════════════════════════════════════════════════════════
# FAST PATH: no FDE passphrase, no btrfs subvolumes
# → delegate entirely to `bootc install to-disk` for the simplest/most reliable
#   path (handles EFI, BIOS boot, partitioning, grub all automatically).
# ══════════════════════════════════════════════════════════════════════════════

if [ "$FDE" != "true" ] || [ "$TPM2" == "true" ]; then
    # bootc install to-disk handles everything
    STEPS=2
    BLOCK_SETUP="direct"
    if [ "$FDE" == "true" ] && [ "$TPM2" == "true" ]; then
        BLOCK_SETUP="tpm2-luks"
        STEPS=3
    fi

    progress_step 1 "$STEPS" "Preparing disk"

    TARGET_ARGS=""
    [ -n "$TARGET_IMGREF" ] && TARGET_ARGS="--target-imgref $TARGET_IMGREF"
    # shellcheck disable=SC2086
    bootc install to-disk \
        --source-imgref "$IMAGE" \
        --wipe \
        --filesystem "$FS_TYPE" \
        --block-setup "$BLOCK_SETUP" \
        --experimental-unified-storage \
        ${BOOTC_SELINUX_FLAG} \
        $TARGET_ARGS \
        "$DEVICE" 2>&1

    if [ "$BLOCK_SETUP" == "tpm2-luks" ]; then
        progress_step 3 "$STEPS" "Finalizing"
    fi

    progress_step "$STEPS" "$STEPS" "Installation complete"

    # Apply hostname to the installed root (fast path: re-mount root partition)
    if [ -n "$HOSTNAME_ARG" ]; then
        _FP_PREFIX="$DEVICE"
        if [[ "$DEVICE" == *"nvme"* || "$DEVICE" == *"mmcblk"* || "$DEVICE" == *"loop"* ]]; then
            _FP_PREFIX="${DEVICE}p"
        fi
        _FP_ROOT=""
        for _try in "${_FP_PREFIX}3" "${_FP_PREFIX}2"; do
            if [ -b "$_try" ]; then
                _FP_ROOT="$_try"
                break
            fi
        done
        if [ -n "$_FP_ROOT" ]; then
            mkdir -p /tmp/hn_mount
            if mount "$_FP_ROOT" /tmp/hn_mount 2>/dev/null; then
                __apply_hostname /tmp/hn_mount
                umount /tmp/hn_mount 2>/dev/null || true
            fi
        fi
    fi

    progress_complete
    exit 0
fi

# ══════════════════════════════════════════════════════════════════════════════
# CUSTOM PATH: passphrase FDE and/or btrfs subvolumes
# → manual partition + format + bootc install to-filesystem
# ══════════════════════════════════════════════════════════════════════════════

TOTAL_STEPS=4
if [ "$FDE" == "true" ]; then
    TOTAL_STEPS=5
fi

# ── Step 1: Partition the disk ─────────────────────────────────────────────────

progress_step 1 "$TOTAL_STEPS" "Creating partition table"

parted "$DEVICE" --script mklabel gpt
parted "$DEVICE" --align=optimal --script mkpart ESP fat32 1MiB 1024MiB
parted "$DEVICE" --script set 1 boot on
parted "$DEVICE" --script type 1 c12a7328-f81f-11d2-ba4b-00a0c93ec93b
parted "$DEVICE" --script mkpart ROOT "$FS_TYPE" 1024MiB 100%
parted "$DEVICE" --script type 2 4F68BCE3-E8CD-4DB1-96E7-FBCAF984B709
partprobe "$DEVICE"

# Handle NVMe/mmcblk/loop partition naming (need 'p' separator)
PART_PREFIX="$DEVICE"
if [[ "$DEVICE" == *"nvme"* || "$DEVICE" == *"mmcblk"* || "$DEVICE" == *"loop"* ]]; then
    PART_PREFIX="${DEVICE}p"
fi

udevadm settle

# ── Step 2: Format partitions ─────────────────────────────────────────────────

progress_step 2 "$TOTAL_STEPS" "Formatting partitions"

mkfs.fat -F 32 -n EFI-SYSTEM "${PART_PREFIX}1"

ROOT_DEV="${PART_PREFIX}2"

# ── Step 3 (optional): Set up LUKS encryption ─────────────────────────────────

if [ "$FDE" == "true" ]; then
    progress_step 3 "$TOTAL_STEPS" "Setting up encryption"

    echo -n "$PASSPHRASE" | cryptsetup luksFormat --type luks2 "${PART_PREFIX}2" -
    echo -n "$PASSPHRASE" | cryptsetup open "${PART_PREFIX}2" tunaos-root -
    ROOT_DEV="/dev/mapper/tunaos-root"

    if [ "$TPM2" == "true" ]; then
        if [ -e /sys/class/tpm/tpm0 ] && command -v systemd-cryptenroll &>/dev/null; then
            echo -n "$PASSPHRASE" | systemd-cryptenroll \
                --tpm2-device=auto --tpm2-pcrs=0+7 \
                "${PART_PREFIX}2" --password || \
                echo '{"type":"warning","message":"TPM2 enrollment failed; passphrase-only encryption active"}'
        else
            echo '{"type":"warning","message":"TPM2 requested but hardware unavailable; skipping TPM2 enroll"}'
        fi
    fi
fi

# ── Format root filesystem ────────────────────────────────────────────────────

case "$FS_TYPE" in
    xfs)   mkfs.xfs -f -L root "$ROOT_DEV" ;;
    ext4)  mkfs.ext4 -F -L root "$ROOT_DEV" ;;
    btrfs) mkfs.btrfs -f -L root "$ROOT_DEV" ;;
esac

# ── Mount root (with optional btrfs subvolumes) ───────────────────────────────

if [ "$BTRFS_SUBVOLS" == "true" ]; then
    # Create top-level subvolumes then mount @ as root
    mount "$ROOT_DEV" "$MOUNT"
    btrfs subvolume create "${MOUNT}/@"
    btrfs subvolume create "${MOUNT}/@home"
    btrfs subvolume create "${MOUNT}/@snapshots"
    umount "$MOUNT"

    BTRFS_OPTS="rw,noatime,compress=zstd,subvol=@"
    mount -o "$BTRFS_OPTS" "$ROOT_DEV" "$MOUNT"
    mkdir -p "${MOUNT}/home" "${MOUNT}/.snapshots"
    mount -o "rw,noatime,compress=zstd,subvol=@home" "$ROOT_DEV" "${MOUNT}/home"
    mount -o "rw,noatime,compress=zstd,subvol=@snapshots" "$ROOT_DEV" "${MOUNT}/.snapshots"
else
    mount "$ROOT_DEV" "$MOUNT"
fi

mkdir -p "${MOUNT}/boot/efi"
mount "${PART_PREFIX}1" "${MOUNT}/boot/efi"

# ── Step N: Install TunaOS ────────────────────────────────────────────────────

if [ "$FDE" == "true" ]; then
    INSTALL_STEP=4
else
    INSTALL_STEP=3
fi
progress_step "$INSTALL_STEP" "$TOTAL_STEPS" "Installing TunaOS (this may take a few minutes)"

TARGET_ARGS2=""
[ -n "$TARGET_IMGREF" ] && TARGET_ARGS2="--target-imgref $TARGET_IMGREF"
# shellcheck disable=SC2086
bootc install to-filesystem \
    --source-imgref "$IMAGE" \
    --experimental-unified-storage \
    ${BOOTC_SELINUX_FLAG} \
    $TARGET_ARGS2 \
    "$MOUNT"

# ── Final step: Finalize ──────────────────────────────────────────────────────

if [ "$FDE" == "true" ]; then
    FINAL_STEP=5
else
    FINAL_STEP=4
fi
progress_step "$FINAL_STEP" "$TOTAL_STEPS" "Finalizing"

__apply_hostname "$MOUNT"
sync
umount -R "$MOUNT"

if [ "$FDE" == "true" ]; then
    cryptsetup close tunaos-root
fi

trap - EXIT

progress_complete "Installation complete!"
